# =============================================================================
# Database Configuration — Benchmark: DuckDB + Parquet vs MySQL / PostgreSQL
# =============================================================================
# Copy this file to .env and fill in the values for your local environment.
# Never commit .env with real credentials to version control.

# -----------------------------------------------------------------------------
# MySQL
# -----------------------------------------------------------------------------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
PG_HOST=localhost
PG_PORT=5432
PG_USER=pocuser
PG_PASSWORD=password
PG_DBNAME=benchmark_poc_db

# -----------------------------------------------------------------------------
# Benchmark settings (shared by all benchmark scripts)
# -----------------------------------------------------------------------------
# Total number of ad-insight rows to generate and load.
# Reduce for quick smoke-tests; 10_000_000 is the full benchmark size.
NUM_ROWS=10_000_000

# Set to 1 to keep the database tables and Parquet files after the run.
# Useful for manual inspection or re-running individual queries.
SKIP_CLEANUP=0
